{
  "name": "Car Parts Side Tagger",
  "type": "app",
  "version": "1.1.2",
  "description": "Assigns object-level side tags (left/right) for pair car parts using existing car view tags and deterministic rules.",
  "categories": [
    "images",
    "annotation",
    "automation"
  ],
  "entrypoint": "python -m uvicorn src.app:server --host 0.0.0.0 --port 8000",
  "port": 8000,
  "task_location": "application_sessions",
  "icon": "https://raw.githubusercontent.com/brshtsk/SuperviselyPartsTags/main/img/logo-ml.png",
  "icon_cover": true,
  "headless": false,
  "docker_image": "supervisely/base-py-sdk:6.73.424"
}

